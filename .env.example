# Supabase — required for real student registration & lecturer data
# https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# After adding keys:
# 1. Copy this file to .env
# 2. Run supabase/schema.sql (new project) OR supabase/migrations/002_student_accounts.sql (existing)
# 3. In Supabase Auth → Providers: enable Email; for testing you may disable "Confirm email"
